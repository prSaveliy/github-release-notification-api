PORT=3000
API_URL=http://localhost:3000

DATABASE_URL=postgresql://user:password@localhost:5432/github_release_notifications?schema=public

# Optional: increases GitHub rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_smtp_password

SCAN_ENABLED=true
SCAN_INTERVAL_MS=600000

REDIS_URL=redis://localhost:6379
GITHUB_CACHE_TTL_SECONDS=600
